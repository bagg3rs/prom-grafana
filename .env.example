# Monitoring Stack Environment Variables

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# Traefik Domain Configuration
GRAFANA=grafana.yourdomain.com
PROMETHEUS=prometheus.yourdomain.com
SNMP=snmp.yourdomain.com
BLACKBOX=blackbox.yourdomain.com
CADVISOR=cadvisor.yourdomain.com
UPTIME=uptime.yourdomain.com

# Home Assistant (optional - if you use it)
# Generate token: Settings → Profile → Long-Lived Access Tokens
HASS_TOKEN=your_home_assistant_token_here
HASS_URL=http://192.168.1.100:8123

# Network Devices for SNMP Monitoring (optional)
# Format: hostname or IP
SNMP_TARGETS=device1.local,device2.local,device3.local

# Blackbox HTTP Probe Targets (optional)
BLACKBOX_HTTP_TARGETS=https://example.com,https://google.com

# Blackbox ICMP Ping Targets (optional)
BLACKBOX_PING_TARGETS=8.8.8.8,1.1.1.1
