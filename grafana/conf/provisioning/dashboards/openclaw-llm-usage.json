{
  "uid": "openclaw-llm-usage",
  "title": "OpenClaw — LLM Model Usage",
  "tags": ["openclaw", "llm", "otel"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Calls / min by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (span_name) (rate(traces_spanmetrics_calls_total{service=\"openclaw-gateway\"}[5m]))",
          "legendFormat": "{{span_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "spanNulls": true }
        }
      }
    },
    {
      "id": 2,
      "title": "P95 Latency by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (span_name, le) (rate(traces_spanmetrics_latency_bucket{service=\"openclaw-gateway\"}[5m])))",
          "legendFormat": "p95 {{span_name}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (span_name, le) (rate(traces_spanmetrics_latency_bucket{service=\"openclaw-gateway\"}[5m])))",
          "legendFormat": "p50 {{span_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        }
      }
    },
    {
      "id": 3,
      "title": "Total Calls by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (span_name) (traces_spanmetrics_calls_total{service=\"openclaw-gateway\"})",
          "legendFormat": "{{span_name}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "title": "Total Output Bytes by Model",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (span_name) (traces_spanmetrics_size_total{service=\"openclaw-gateway\"})",
          "legendFormat": "{{span_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (span_name, status_code) (rate(traces_spanmetrics_calls_total{service=\"openclaw-gateway\", status_code!=\"STATUS_CODE_UNSET\"}[5m]))",
          "legendFormat": "{{span_name}} ({{status_code}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 6,
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "nativeSearch",
          "serviceName": "openclaw-gateway",
          "limit": 20
        }
      ]
    }
  ],
  "schemaVersion": 39
}
