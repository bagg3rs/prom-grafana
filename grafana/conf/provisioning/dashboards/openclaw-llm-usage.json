{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "tempo", "name": "Tempo", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "OpenClaw LLM model usage — calls by model, token usage, latency",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Model Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Rate of LLM calls per model over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ service.name = \"openclaw-gateway\" && span.gen_ai.request.model != \"\" } | rate() by(span.gen_ai.request.model)",
          "refId": "A"
        }
      ],
      "title": "Calls / min by Model",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Output tokens per model over time",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["sum", "mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ service.name = \"openclaw-gateway\" && span.gen_ai.usage.output_tokens > 0 } | sum(span.gen_ai.usage.output_tokens) by(span.gen_ai.request.model)",
          "refId": "A"
        }
      ],
      "title": "Output Tokens by Model",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "P95 response latency per model",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ service.name = \"openclaw-gateway\" && span.gen_ai.request.model != \"\" } | quantile_over_time(duration, 0.95) by(span.gen_ai.request.model)",
          "refId": "A"
        }
      ],
      "title": "P95 Latency by Model",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Model usage breakdown",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] },
        "pieType": "pie",
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ service.name = \"openclaw-gateway\" && span.gen_ai.request.model != \"\" } | count() by(span.gen_ai.request.model)",
          "refId": "A"
        }
      ],
      "title": "Model Distribution",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 11,
      "title": "Recent Traces",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Recent LLM calls — click to open trace",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": { "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "filters": [
            { "id": "service-name", "operator": "=", "scope": "resource", "tag": "service.name", "value": "openclaw-gateway" },
            { "id": "gen-ai-model", "operator": "!=", "scope": "span", "tag": "gen_ai.request.model", "value": "" }
          ],
          "limit": 50,
          "queryType": "nativeSearch",
          "refId": "A"
        }
      ],
      "title": "Recent Model Calls",
      "type": "traces"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["openclaw", "llm", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenClaw — LLM Model Usage",
  "uid": "openclaw-llm-usage",
  "version": 1
}
